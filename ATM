bool ShouldContinue(const string& Message)
{
	char Response;
	cout << Message;
	cin >> Response;
	return (Response == 'y' || Response == 'Y');
}

vector<string> SplitString(string S1, const string& Delim)
{
	vector<string> vString;
	short pos = 0;
	string sWord;
	while ((pos = S1.find(Delim)) != std::string::npos)
	{
		sWord = S1.substr(0, pos);
		if (sWord != "")
		{
			vString.push_back(sWord);
		}
		S1.erase(0, pos + Delim.length());
	}
	if (S1 != "")
	{
		vString.push_back(S1);
	}
	return vString;
}

ClientData ConverLineToRecored(string& line, string Dlime = "#//#")
{
	vector<string> vString;

	vString = SplitString(line, Dlime);

	ClientData Client;
	Client.AccountNumber = vString[0];
	Client.PINCode = vString[1];
	Client.ClientName = vString[2];
	Client.PhoneNumber = vString[3];
	Client.AccountBalanced = stod(vString[4]);

	return Client;
}

void LoadDataFromFileToVector(string FileName, vector<ClientData>& VFileContent)
{
	fstream Myfile;
	ClientData Client;
	Myfile.open(FileName, ios::in);

	if (Myfile.is_open())
	{
		string Line;
		while (getline(Myfile, Line))
		{
			if (!Line.empty()) {
				Client = ConverLineToRecored(Line);
				VFileContent.push_back(Client);
			}
		}
		Myfile.close();
	}
}

string ConverRecoredToLine(ClientData& ClientData, string Seperator = "#//#")
{
	string Line = "";
	Line += ClientData.AccountNumber + Seperator;
	Line += ClientData.PINCode + Seperator;
	Line += ClientData.ClientName + Seperator;
	Line += ClientData.PhoneNumber + Seperator;
	Line += to_string(ClientData.AccountBalanced);

	return Line;
}

void SaveVectorToFile(string FileName, vector<ClientData>& VClientData)
{
	fstream Myfile;
	string Line = "";
	Myfile.open(FileName, ios::out);
	if (Myfile.is_open())
	{
		for (ClientData& Client : VClientData)
		{
			Line = ConverRecoredToLine(Client, "#//#");
			if (Line != "")
			{
				Myfile << Line << endl;
			}
		}
		Myfile.close();
	}
}

