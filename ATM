vector<string> SplitString(string S1, const string& Delim)
{
	vector<string> vString;
	short pos = 0;
	string sWord;
	while ((pos = S1.find(Delim)) != std::string::npos)
	{
		sWord = S1.substr(0, pos);
		if (sWord != "")
		{
			vString.push_back(sWord);
		}
		S1.erase(0, pos + Delim.length());
	}
	if (S1 != "")
	{
		vString.push_back(S1);
	}
	return vString;
}

ClientData ConverLineToRecored(string& line, string Dlime = "#//#")
{
	vector<string> vString;

	vString = SplitString(line, Dlime);

	ClientData Client;
	Client.AccountNumber = vString[0];
	Client.PINCode = vString[1];
	Client.ClientName = vString[2];
	Client.PhoneNumber = vString[3];
	Client.AccountBalanced = stod(vString[4]);

	return Client;
}

stUserData ConvertLineToUserRecord(const string& line, const string Delim = "#//#")
{
	vector<string> vString;
	stUserData  User;
	if (line.empty())
	{
		return 	 User;
	}
	vString = SplitString(line, Delim);
	if (vString[0] == "" || vString[1] == "" || stod(vString[2]) == 0) {
		return User;
	}




	User.UserName = vString[0];
	User.Password = vString[1];
	User.Permissions = stoi(vString[2]);


	return User;
}

void LoadDataFromFileToVector(string FileName, vector<ClientData>& VFileContent)
{
	fstream Myfile;
	ClientData Client;
	Myfile.open(FileName, ios::in);

	if (Myfile.is_open())
	{
		string Line;
		while (getline(Myfile, Line))
		{
			if (!Line.empty()) {
				Client = ConverLineToRecored(Line);
				VFileContent.push_back(Client);
			}
		}
		Myfile.close();
	}
}

void LoadDataFromFileToVector(const string& FileName, vector<stUserData>& vUserData)
{
	fstream MyFile;
	stUserData User;


	MyFile.open(FileName, ios::in);

	if (MyFile.is_open())
	{
		string Line;

		while (getline(MyFile, Line))
		{

			User = ConvertLineToUserRecord(Line);
			if (User.UserName == "")
			{
				continue;
			}
			vUserData.push_back(User);
		}

		MyFile.close();
	}
	
}

string ConverRecoredToLine(ClientData& ClientData, string Seperator = "#//#")
{
	string Line = "";
	Line += ClientData.AccountNumber + Seperator;
	Line += ClientData.PINCode + Seperator;
	Line += ClientData.ClientName + Seperator;
	Line += ClientData.PhoneNumber + Seperator;
	Line += to_string(ClientData.AccountBalanced);

	return Line;
}

string ConvertRecordToUserLine(const stUserData& User, const string Separator = "#//#")
{
	string Line = "";
	Line += User.UserName + Separator;
	Line += User.Password + Separator;
	Line += to_string(User.Permissions);
	return Line;
}

void SaveVectorToFile(string FileName, vector<ClientData>& VClientData)
{
	fstream Myfile;
	string Line = "";
	Myfile.open(FileName, ios::out);
	if (Myfile.is_open())
	{
		for (ClientData& Client : VClientData)
		{
			Line = ConverRecoredToLine(Client, "#//#");
			if (Line != "")
			{
				Myfile << Line << endl;
			}
		}
		Myfile.close();
	}
}

void SaveVectorToUserFile(const string& FileName, vector<stUserData>& vUserData)
{
	fstream MyFile;
	string Line = "";
	MyFile.open(FileName, ios::out);
	if (MyFile.is_open())
	{
		for (stUserData& User : vUserData)
		{
			Line = ConvertRecordToUserLine(User, "#//#");
			if (Line != "")
			{
				MyFile << Line << endl;
			}
		}

		MyFile.close();
	}
}

bool HasAuthenticate(const int UserPermission, const enPermissions FeaturePermmsion)
{
	if (UserPermission == enPermissions::FullControl)
	{
		return true;
	}
	return ((UserPermission & FeaturePermmsion) == FeaturePermmsion);
}

