void ReadNewClientData(ClientData& ClientsData, vector<ClientData>& VClientData)
{
	bool Exist;
	do
	{
		cout << "Enter Account Number ? ";
		getline(cin >> ws, ClientsData.AccountNumber);
		cout << "\n";

		ClientData DummyClient;
		bool IsExist = ClientIsExist(VClientData, ClientsData.AccountNumber, DummyClient);
		Exist = IsExist;

		if (!(IsExist))
		{
			ReadNewClientDataToUpdating(ClientsData);
		}
		else
		{
			cout << "This Client Is Already Exist. Please enter a different Account Number\n";
		}
	} while (Exist);
}

