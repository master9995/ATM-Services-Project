		{
			printUserInfo(true, User);

			if (ConfirmDelete("\nAre you sure you want to delete this user? (Y/N): "))
			{
				vector<stUserData> VUpdatedUsers;

				for (const stUserData& U : vUserData)
				{

					if (U.UserName != UserNameWantedToDeleted)
					{
						VUpdatedUsers.push_back(U);
					}
				}


				SaveVectorToUserFile(UserAuthenticationFileName, VUpdatedUsers);

				cout << "\nThe Delete Is Successful!\n";
			}
			else
			{
				cout << "\nDeletion Cancelled.\n";
			}
		}
		else
		{

			cout << "\nUser With User Name (" << UserNameWantedToDeleted << ") is Not Found!\n";
		}
	}
	else
	{
		cout << "\nThis User Is [ Admin ] Musnt Deleted\n";
	}


}

