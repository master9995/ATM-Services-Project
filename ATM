void UpdataClientData()
{
	ClientData NewClientData;

	vector<ClientData> VClientData;
	
	LoadDataFromFileToVector(ClientsFileName, VClientData);

	ShowUpdateClientScreen();

	string AccountNumber = ReadAccountNumber("Please Enter Your Account Number You Want To Update It ? \n");

	if (ClientIsExist(VClientData, AccountNumber, NewClientData))
	{
		printClientInfo(true, NewClientData, AccountNumber);

		if (ShouldContinue("Do You Want To Continue Updating Client Data ? (Y/N) "))
		{
			ReadNewClientDataToUpdating(NewClientData);

			for (ClientData& Client : VClientData)
			{
				if (Client.AccountNumber == AccountNumber)
				{
					Client = NewClientData;
				
					Client.AccountNumber = AccountNumber;
					break;
				}
			}

			SaveVectorToFile(ClientsFileName, VClientData);

			cout << "\nClient Updated Successfully.\n";
		}
		else
		{
			cout << "\nUpdating Client Data Canceled \n";
		}
	}
	else
	{
		cout << "\nThis Client Not Found\n";
	}
}

