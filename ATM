void DeleteRecordFromFile(const string& ClientsFileName, vector<ClientData>& VClientData, ClientData& PClient)
{
	ShowDeleteClientScreen();
	string ClientAccountWantedToDeleted = ReadAccountNumber("Please Enter Your Account Number ?");

	bool IsExist = ClientIsExist(VClientData, ClientAccountWantedToDeleted, PClient);

	if (IsExist)
	{
		printClientInfo(IsExist, PClient, ClientAccountWantedToDeleted);

		if (ConfirmDelete("\nAre you sure you want to delete this client? (Y/N): "))
		{

			unsigned int WriteIndex = 0;

			unsigned int VectorSize = VClientData.size();

			for (unsigned int ReadIndex = 0; ReadIndex < VectorSize; ReadIndex++)
			{
				if (VClientData[ReadIndex].AccountNumber != ClientAccountWantedToDeleted)
				{
					VClientData[WriteIndex] = VClientData[ReadIndex];
					WriteIndex++;
				}
			}

			while (VectorSize - WriteIndex != 0)
			{
				VClientData.pop_back();
				VectorSize--;
			}


			SaveVectorToFile(ClientsFileName, VClientData);

			cout << "The Deleted Is Successfully";

		}

		else
		{
			cout << "\nDeletion Cancelled.\n";
			return;
		}

	}

	else
	{
		cout << "\nClient With Account Number(" << ClientAccountWantedToDeleted << ") is Not Found : \n";

	}

}



