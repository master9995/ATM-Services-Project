double ReadTransactionAmount(const string& Message)
{
	double DepositAmount = 0;
	do
	{
		cout << Message << "\n";

		cin >> DepositAmount;

	} while (DepositAmount <= 0);

	return DepositAmount;
}

void DepositProcess()
{
	ClientData Client;

	vector<ClientData> VClientData;

	LoadDataFromFileToVector(ClientsFileName, VClientData);

	ShowDepositScreen();

	string AccountNumber = ReadAccountNumber("Please Enter Account Number: ");

	if (ClientIsExist(VClientData, AccountNumber, Client))
	{
		printClientInfo(true, Client, AccountNumber);

		double DepositAmount = ReadTransactionAmount("please enter deposit amount ? ");

		if (ShouldContinue("are you sure you want to perform this transaction ? (Y) OR (N)\n"))
		{
			for (ClientData& C : VClientData)
			{
				if (C.AccountNumber == AccountNumber)
				{
					C.AccountBalanced += DepositAmount;
					break;
				}
			}

			SaveVectorToFile(ClientsFileName, VClientData);

			cout << "\nTransaction Done Successfully.\n";
		}
	}
	else
	{
		cout << "\n-----------------------------------";
		cout << "\nSorry, this client was not found!";
		cout << "\n-----------------------------------\n";
	}
}

