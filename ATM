void DeleteClientProcess()
{
	stUserData User = CurrentUser;

	if (HasAuthenticate(User.Permissions, enPermissions::DeleteClients))
	{
		ClientData PClient;

		vector<ClientData> vClientData;

		LoadDataFromFileToVector(ClientsFileName, vClientData);

		ShowDeleteClientScreen();

		string ClientAccountWantedToDeleted = ReadAccountNumber("Please Enter Your Account Number ? ");

		if (IsClientExist(vClientData, ClientAccountWantedToDeleted, PClient))
		{
			printClientInfo(true, PClient, ClientAccountWantedToDeleted);

			if (ConfirmDelete("\nAre you sure you want to delete this client? (Y/N): "))
			{

				vector<ClientData> VUpdatedClients;

				for (const ClientData& Client : vClientData)
				{
					if (Client.AccountNumber != ClientAccountWantedToDeleted)
					{
						VUpdatedClients.push_back(Client);
					}
				}

				SaveVectorToFile(ClientsFileName, VUpdatedClients);
				cout << "The Delete Is Successfully";
			}
			else
			{
				cout << "\nDeletion Cancelled.\n";
			}
		}
		else
		{
			cout << "\nClient With Account Number (" << ClientAccountWantedToDeleted << ") is Not Found : \n";
		}
	}
	else
	{
		ShowAccessDeniedScreen();
	
	}
}

