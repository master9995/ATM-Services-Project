enPermissions CalcatePermmsion()
{
	int  Permmision = 0;

	if (ReadPerrmison("\ndo you want to give full access? Y\\n ") == true)
		return enPermissions::FullControl;

	cout << "\ndo you want to give access To  : \n";

	if (ReadPerrmison("\nShow Client List ? Y\\n ") == true)
		Permmision += enPermissions::ShowClientsList;

	if (ReadPerrmison("\nAdd New Client ? Y\\n ") == true)
		Permmision += enPermissions::AddNewClients;

	if (ReadPerrmison("\nDelete Client ? Y\\n ") == true)
		Permmision += enPermissions::DeleteClients;

	if (ReadPerrmison("\nFind Client ? Y\\n ") == true)
		Permmision += enPermissions::FindClients;

	if (ReadPerrmison("\nUpdate Client Info ? Y\\n ") == true)
		Permmision += enPermissions::UpdateClientsInfo;

	if (ReadPerrmison("\nTransactions ? Y\\n ") == true)
		Permmision += enPermissions::TransactionsPermission;

	int AllPermissionsSum = enPermissions::ShowClientsList +
		enPermissions::AddNewClients +
		enPermissions::DeleteClients +
		enPermissions::FindClients +
		enPermissions::UpdateClientsInfo +
		enPermissions::TransactionsPermission;

	if (Permmision == AllPermissionsSum)
		return enPermissions::FullControl;

	return enPermissions(Permmision);
}

