		GoBackToMainMenue();
		break;

	case MainMenueItems::DeleteClien:
		system("cls");
		DeleteRecordFromFile(ClientsFileName, VClientData, PClient);
		GoBackToMainMenue();
		break;

	case MainMenueItems::updataClientInfo:
		system("cls");
		UpdataClientData(ClientsFileName, VClientData, PClient);
		GoBackToMainMenue();
		break;

	case MainMenueItems::FindClient:
