void UpdataClientData(string ClientsFileName, vector<ClientData>& VClientData, ClientData& NewClientData)
{
	ShowUpdateClientScreen();
	string AccountNumber = "";

	AccountNumber = ReadAccountNumber("Please Enter Your Account Number You Want To Updata It ? \n");
	bool IsExist = ClientIsExist(VClientData, AccountNumber, NewClientData);

	if (IsExist)
	{
		printClientInfo(true, NewClientData, AccountNumber);
		if (ShouldContinue("Do You Wante To Continue Updating Client Data ?"))
		{
			ReadNewClientDataToUpdating(NewClientData);

			UpdateRecordInFile(ClientsFileName, AccountNumber, NewClientData, VClientData);
		}
		else
		{
			{
				cout << "\nUpdataing Client Data Canceled \n";
			}
		}



	}
	else
	{
		cout << "\nThis Client Not Found\n";

		return;
	}


}

