bool AuthenticateUserToLogin(const vector<stUserData>& vUserData, stUserData& User)
{
	for (const stUserData& TempUser : vUserData)
	{
		if (User.UserName == TempUser.UserName && User.Password == TempUser.Password)
		{
			User = TempUser;
			return true;
		}
	}
	return false;
}

bool Login()
{

	bool LoginFailed = false;

	do
	{
		vector<stUserData> vUserData;

		stUserData  User;

		LoadDataFromFileToVector(UserAuthenticationFileName, vUserData);

		system("cls");

		LoginScreenHeader();

		if (LoginFailed)
		{
			cout << "Invlaid Username OR Password!\n";
		}

		User = InputLogicScreen("Please Enter Your User Name? ", "Please Enter Your Password? ");

		if (AuthenticateUserToLogin(vUserData, User))
		{
			CurrentUser = User;
			return true;
		}
		else
		{
			LoginFailed = true;
		}

	} while (LoginFailed);

	return false;
}

