	vector<stUserData> vUserData;

	LoadDataFromFileToVector(UserAuthenticationFileName, vUserData);

	ShowDeleteUserScreen();

	string UserNameWantedToDeleted = ReadAccountNumber("Please Enter Your user Name ? ");

